/* ===================== UI LOGIC ===================== */
const weeks=document.getElementById("weeks");
const content=document.getElementById("content");

for(let i=1;i<=12;i++){
  const w=document.createElement("div");
  w.className="week";
  w.innerText=i;
  w.onclick=()=>showWeek(i,w);
  weeks.appendChild(w);
}

function showWeek(num,el){
  document.querySelectorAll(".week").forEach(w=>w.classList.remove("active"));
  el.classList.add("active");
  content.innerHTML="";
  Object.values(program[num]||{}).forEach(day=>{
    const d=document.createElement("div");
    d.className="day";
    const t=document.createElement("div");
    t.className="day-title";
    t.innerText=day.title;
    const wks=document.createElement("div");
    wks.className="workouts";
    day.workouts.forEach(w=>{
      const wd=document.createElement("div");
      wd.className="workout";
      wd.innerHTML=
        `<div class="workout-title">${w.name}</div>` +
        w.details.map(x=>`<div>- ${x}</div>`).join("");
      wks.appendChild(wd);
    });
    t.onclick=()=>wks.style.display=wks.style.display==="block"?"none":"block";
    d.appendChild(t);
    d.appendChild(wks);
    content.appendChild(d);
  });
}
